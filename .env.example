# Optional environment overrides.
# Preferred local configuration: copy config/user.example.yaml to config/user.yaml.

# LLM API Configuration (Qwen / DashScope OpenAI-compatible endpoint)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_PROVIDER=qwen
LLM_MODEL=qwen-plus
LLM_TIMEOUT=60

# Backward-compatible alternatives
LLM_API_KEY=your_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Proxy (auto-detected, override here if needed)
HTTP_PROXY=http://127.0.0.1:7899
HTTPS_PROXY=http://127.0.0.1:7899
